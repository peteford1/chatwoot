# Chatwoot Azure Database Configuration
# Generated on 2025-01-27
# Source this file to connect to Azure PostgreSQL database

# ============================================================================
# DATABASE CONFIGURATION (Azure PostgreSQL)
# ============================================================================

export POSTGRES_HOST=chatwoot-postgres-test.postgres.database.azure.com
export POSTGRES_PORT=5432
export POSTGRES_DATABASE=chatwoot_production
export POSTGRES_USERNAME=chatwoot_admin
export POSTGRES_PASSWORD=VoiceLinkAI2024!

# Connection Pool Settings
export RAILS_MAX_THREADS=5
export SIDEKIQ_CONCURRENCY=10
export DB_POOL_REAPING_FREQUENCY=30
export POSTGRES_STATEMENT_TIMEOUT=14s

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis connection (use local Redis without authentication)
export REDIS_URL=redis://localhost:6379
export REDIS_OPENSSL_VERIFY_MODE=none

# Ensure no Redis password is set (causes AUTH errors if empty)
unset REDIS_PASSWORD

# ============================================================================
# RAILS ENVIRONMENT
# ============================================================================

# Set Rails environment to production to use production database config
export RAILS_ENV=production

# ============================================================================
# CHATWOOT APPLICATION SETTINGS
# ============================================================================

# Base URL for API calls
export CHATWOOT_API_BASE_URL=https://chatwoot-backend-test.calmmushroom-30b1c815.eastus.azurecontainerapps.io

# Frontend URL (if needed)
export FRONTEND_URL=https://chatwoot-frontend-test.calmmushroom-30b1c815.eastus.azurecontainerapps.io

# ============================================================================
# AUTHENTICATION TOKENS (From User)
# ============================================================================

# Admin user and tokens
export CHATWOOT_ADMIN_USER_ID=1
export CHATWOOT_ADMIN_TOKEN="J8mwDmmcZbuYs6a672oT8TW6"
export CHATWOOT_PLATFORM_TOKEN="eb7Mc8LxE44ErjsdgS67Aqz6"

# Set primary token for testing
export CHATWOOT_USER_TOKEN="J8mwDmmcZbuYs6a672oT8TW6"
export CHATWOOT_USER_ID=1

# ============================================================================
# SSL AND SECURITY SETTINGS
# ============================================================================

# Force SSL connections to database
export POSTGRES_SSLMODE=require

# Rails security settings for production
export RAILS_SERVE_STATIC_FILES=true
export RAILS_LOG_TO_STDOUT=true

echo "🚀 Azure Database Configuration Loaded"
echo "   Database Host: $POSTGRES_HOST"
echo "   Database Name: $POSTGRES_DATABASE"
echo "   Rails Environment: $RAILS_ENV"
echo "   API Base URL: $CHATWOOT_API_BASE_URL" 