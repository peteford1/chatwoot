        "User-Agent",
        "X-Twilio-Signature"
      ],
      "extra_config": {
        "security/policies": {
          "max_conn": 200,
          "max_conn_per_ip": 100
        },
        "qos/ratelimit/router": {
          "max_rate": 500,
          "client_max_rate": 50,
          "strategy": "ip"
        }
      },
      "backend": [
        {
          "url_pattern": "/twilio/callback",
          "encoding": "no-op",
          "method": "POST",
          "host": [
