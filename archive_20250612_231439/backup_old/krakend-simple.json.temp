  "extra_config": {
    "security/cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS", "HEAD"],
      "allow_headers": ["*"],
      "expose_headers": ["*"],
      "max_age": "12h",
      "allow_credentials": false,
      "debug": true
    },
    "telemetry/logging": {
      "level": "INFO",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
