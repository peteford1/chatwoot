{
  "$schema": "https://www.krakend.io/schema/v2.4/krakend.json",
  "version": 3,
  "name": "VoiceLink AI Gateway - Simple",
  "timeout": "30s",
  "cache_ttl": "300s",
  "port": 8080,
  "endpoints": [
    {
      "endpoint": "/health",
      "method": "GET",
      "output_encoding": "json",
      "extra_config": {
        "proxy": {
          "static": {
            "data": {
              "status": "ok",
              "service": "krakend-gateway"
            },
            "strategy": "always"
          }
        }
      },
      "backend": [
        {
          "url_pattern": "/",
          "method": "GET",
          "host": ["https://httpbin.org"],
          "disable_host_sanitize": false
        }
      ]
    },
    {
      "endpoint": "/api/v1/messages",
      "method": "GET",
      "output_encoding": "no-op",
      "headers_to_pass": [
        "Content-Type",
        "Authorization",
        "X-User-ID",
        "X-User-Role",
        "User-Agent"
      ],
      "backend": [
        {
          "url_pattern": "/api/v1/search/messages",
          "encoding": "no-op",
          "method": "GET",
          "host": [
            "https://chatwoot-fresh.calmmushroom-30b1c815.eastus.azurecontainerapps.io"
          ]
        }
      ]
    },
    {
      "endpoint": "/api/v1/accounts/{account_id}/search/messages",
      "method": "GET",
      "output_encoding": "no-op",
      "headers_to_pass": [
        "Content-Type",
        "Authorization",
        "X-User-ID",
        "X-User-Role",
        "User-Agent"
      ],
      "backend": [
        {
          "url_pattern": "/api/v1/accounts/{account_id}/search/messages",
          "encoding": "no-op",
          "method": "GET",
          "host": [
            "https://chatwoot-fresh.calmmushroom-30b1c815.eastus.azurecontainerapps.io"
          ]
        }
      ]
    },
    {
      "endpoint": "/api",
      "method": "GET",
      "output_encoding": "json",
      "extra_config": {
        "proxy": {
          "static": {
            "data": {
              "version": "4.2.0",
              "timestamp": "2025-06-05T01:43:00Z",
              "queue_services": "ok",
              "data_services": "ok",
              "status": "healthy",
              "gateway": "krakend-v2.4.1"
            },
            "strategy": "always"
          }
        }
      },
      "backend": [
        {
          "url_pattern": "/",
          "method": "GET", 
          "host": ["https://httpbin.org"],
          "disable_host_sanitize": false
        }
      ]
    },
    {
      "endpoint": "/api/v1/accounts/{account_id}/conversations",
