{
  "version": 3,
  "name": "KrakenD API Gateway - Debug Version",
  "timeout": "3000ms",
  "cache_ttl": "300s",
  "output_encoding": "no-op",
  "debug_endpoint": true,
  "echo_endpoint": true,
  "extra_config": {
    "telemetry/logging": {
      "level": "DEBUG",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true,
      "format": "default"
    },
    "telemetry/metrics": {
      "collection_time": "60s",
      "proxy_disabled": false,
      "router_disabled": false,
      "backend_disabled": false,
      "endpoint_disabled": false,
      "listen_address": ":8090"
    }
  },
  "host": [
    "https://chatwoot-backend-test.calmmushroom-30b1c815.eastus.azurecontainerapps.io"
  ],
  "endpoints": [
    {
      "endpoint": "/auth/sign_in",
      "method": "POST",
      "output_encoding": "no-op",
      "headers_to_pass": [
        "Content-Type",
        "User-Agent"
      ],
      "backend": [
        {
          "url_pattern": "/auth/sign_in",
          "encoding": "no-op",
          "method": "POST",
          "host": [
            "https://chatwoot-backend-test.calmmushroom-30b1c815.eastus.azurecontainerapps.io"
          ],
          "extra_config": {
            "backend/http": {
              "return_error_code": true
            }
          }
        }
      ]
    },
    {
      "endpoint": "/auth/validate_token",
      "method": "GET",
      "output_encoding": "no-op",
      "headers_to_pass": [
        "Content-Type",
        "access-token",
        "client",
        "uid",
        "token-type",
        "expiry",
        "User-Agent"
      ],
      "backend": [
        {
          "url_pattern": "/auth/validate_token",
          "encoding": "no-op",
          "method": "GET",
          "host": [
            "https://chatwoot-backend-test.calmmushroom-30b1c815.eastus.azurecontainerapps.io"
          ],
          "extra_config": {
            "backend/http": {
              "return_error_code": true
            }
          }
        }
      ]
    },
    {
      "endpoint": "/api/v1/profile",
      "method": "GET",
      "output_encoding": "no-op",
      "headers_to_pass": [
        "Content-Type",
        "Authorization",
        "access-token",
        "client",
        "uid",
        "token-type",
        "expiry",
        "User-Agent",
        "Accept",
        "Cache-Control",
        "X-Requested-With"
      ],
      "extra_config": {
        "modifier/lua-endpoint": {
          "sources": [
            "debug_headers.lua"
          ],
          "allow_open_libs": false
        }
      },
      "backend": [
        {
          "url_pattern": "/api/v1/profile",
          "encoding": "no-op",
          "method": "GET",
          "host": [
            "https://chatwoot-backend-test.calmmushroom-30b1c815.eastus.azurecontainerapps.io"
          ],
          "extra_config": {
            "modifier/lua-backend": {
              "sources": [
                "debug_headers.lua"
              ],
              "allow_open_libs": false
            },
            "backend/http": {
              "return_error_code": true
            }
          }
        }
      ]
    }
  ]
} 