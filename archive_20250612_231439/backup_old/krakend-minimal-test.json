{
  "version": 3,
  "name": "KrakenD Minimal Test",
  "timeout": "3000ms",
  "cache_ttl": "300s",
  "output_encoding": "no-op",
  "port": 8080,
  "endpoints": [
    {
      "endpoint": "/auth/validate_token",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": [
        "Content-Type",
        "access-token",
        "client",
        "uid",
        "token-type",
        "expiry",
        "User-Agent"
      ],
      "backend": [
        {
          "url_pattern": "/auth/validate_token",
          "encoding": "no-op",
          "method": "GET",
          "host": [
            "https://chatwoot-backend-test.calmmushroom-30b1c815.eastus.azurecontainerapps.io"
          ],
          "extra_config": {
            "backend/http": {
              "return_error_code": true
            }
          }
        }
      ]
    },
    {
      "endpoint": "/api/v1/profile",
      "method": "GET",
      "output_encoding": "no-op",
      "input_headers": [
        "Content-Type",
        "Authorization",
        "access-token",
        "client",
        "uid",
        "token-type",
        "expiry",
        "User-Agent",
        "Accept",
        "Cache-Control",
        "X-Requested-With"
      ],
      "backend": [
        {
          "url_pattern": "/api/v1/profile",
          "encoding": "no-op",
          "method": "GET",
          "host": [
            "https://chatwoot-backend-test.calmmushroom-30b1c815.eastus.azurecontainerapps.io"
          ],
          "extra_config": {
            "backend/http": {
              "return_error_code": true
            }
          }
        }
      ]
    }
  ]
} 